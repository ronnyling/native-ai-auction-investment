  "displayRules": [
    {
      "query": "",
      "preset": true,
      "iconDetails": {
        "prefix": "fas",
        "icon": "fa-circle",
        "markerColor": "blue",
        "opacity": 0.8
      }
    },
    {
      "query": "[status:bid]",
      "preset": false,
      "iconDetails": {
        "prefix": "fas",
        "icon": "fa-gavel",
        "markerColor": "red"
      }
    },
    {
